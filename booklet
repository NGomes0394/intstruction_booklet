    c.setFont("Helvetica", 9)
    c.setFillColor(TEXT_LIGHT)
    c.drawCentredString(PAGE_W / 2, 30, str(page_num))
    c.restoreState()


def draw_header_bar(c, text, y=None, color=None):
    """Draw a colored header bar across the page."""
    if y is None:
        y = PAGE_H - 50
    c.saveState()
    c.setFillColor(color or ACCENT)
    c.rect(0, y, PAGE_W, 36, fill=1, stroke=0)
    c.setFillColor(white)
    c.setFont("Helvetica-Bold", 14)
    c.drawString(MARGIN, y + 11, text)
    c.restoreState()
    return y


